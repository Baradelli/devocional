// Schema do banco — único banco para todo o monólito modular.
// Identificadores e schema sempre em inglês (ver CLAUDE.md).
// M0: datasource + generator apenas; os modelos chegam a partir do M1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

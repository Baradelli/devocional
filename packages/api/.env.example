# Conexão do Postgres usada pelo Prisma (dev local).
# Os testes de integração NÃO usam este valor — sobem um Postgres efêmero via Testcontainers.
DATABASE_URL="postgresql://devocional:devocional@localhost:5432/devocional?schema=public"

# Porta do servidor Fastify (opcional; default 3000).
PORT=3000

# Web Push (VAPID). Gere o par com: npx web-push generate-vapid-keys
# Sem as chaves, o canal de push vira no-op logado (o app roda sem push).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@devocional.app"

# URL do app do fiel (usada no clique da notificação).
APP_URL="http://localhost:5173"

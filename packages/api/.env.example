# Conexão do Postgres usada pelo Prisma (dev local).
# Os testes de integração NÃO usam este valor — sobem um Postgres efêmero via Testcontainers.
DATABASE_URL="postgresql://devocional:devocional@localhost:5432/devocional?schema=public"

# Porta do servidor Fastify (opcional; default 3000).
PORT=3000
